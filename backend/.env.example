# Backend API environment variables
# Copy this file to `.env` and fill in real values.

# MongoDB connection string for the Node/Express backend
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# Port for the Express server
PORT=5000

# Secret used to sign and verify JWTs
JWT_SECRET=replace-with-a-long-random-secret

# JWT expiration, for example: 1d, 7d, 30d
JWT_EXPIRES_IN=7d

# Base URL of the Python microservice used by the backend
# Local dev: http://127.0.0.1:8000
PYTHON_AI_API_URL=http://127.0.0.1:8000

# Request timeout in milliseconds for the Python service
PYTHON_AI_TIMEOUT_MS=30000

# Cloudinary credentials for evidence uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Optional full Cloudinary URL format
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# Groq API settings used for search insights
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=20000

# Optional runtime mode
NODE_ENV=development